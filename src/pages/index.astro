---

<Layout>
  <!-- ===================== NAV ===================== -->
  <header
    id="nav"
    class="fixed inset-x-0 top-0 z-[100] border-b border-transparent py-3.5 transition-all duration-300 [&.scrolled]:border-border [&.scrolled]:bg-[rgba(13,13,15,0.85)] [&.scrolled]:py-2.5 [&.scrolled]:backdrop-blur-xl">
    <div class="mx-auto flex w-[min(1160px,92vw)] items-center justify-between gap-4">
      <a href="#top" aria-label="Candir" class="group inline-flex shrink-0 items-center gap-[9px]">
        <span
          class="grid h-[30px] w-[30px] shrink-0 place-items-center rounded-lg bg-accent transition-transform duration-300 group-hover:-rotate-[8deg]">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path
              d="M8 1.5C4.41 1.5 1.5 4.41 1.5 8C1.5 11.59 4.41 14.5 8 14.5C11.59 14.5 14.5 11.59 14.5 8"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"></path>
            <path
              d="M11 4L14.5 4L14.5 7.5"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path d="M14.5 4L9 9.5" stroke="white" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
        </span>
        <span class="font-sans text-[15px] font-bold tracking-[0.12em] text-text">CANDIR</span>
      </a>

      <nav
        id="navLinks"
        class="flex ml-auto gap-0.5 max-md:fixed max-md:inset-x-0 max-md:bottom-0 max-md:top-[58px] max-md:z-[99] max-md:invisible max-md:-translate-y-4 max-md:flex-col max-md:border-b max-md:border-border max-md:bg-black max-md:px-[5vw] max-md:pb-5 max-md:pt-3.5 max-md:opacity-0 max-md:backdrop-blur-xl max-md:transition-all max-md:duration-300 max-md:[&.open]:visible max-md:[&.open]:translate-y-0 max-md:[&.open]:opacity-100">
        {
          navLinks.map(l => (
            <a
              href={l.href}
              class="rounded-lg px-3 py-[7px] text-[13.5px] font-medium text-text-2 transition-colors hover:bg-surface hover:text-text max-md:px-4 max-md:py-[13px] max-md:text-base">
              {l.label}
            </a>
          ))
        }
      </nav>

      <div class="ml-3 flex items-center gap-2">
        <a
          href={salon.phoneBookingHref}
          title="Pozovi"
          class="flex items-center gap-[7px] rounded-lg border border-border px-3 py-[7px] text-[13px] text-text-2 transition-colors hover:border-border-hi hover:bg-surface hover:text-text">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8">
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.81.37 1.6.72 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.74-1.01a2 2 0 0 1 2.11-.45c.74.35 1.53.6 2.34.72A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span class="hidden min-[1080px]:block">{salon.phoneBooking}</span>
        </a>
        <a
          href="#booking"
          class="inline-flex items-center gap-[7px] whitespace-nowrap rounded-lg bg-accent px-4 py-2 text-[13.5px] font-semibold text-white transition hover:-translate-y-px hover:bg-accent-2 max-md:hidden">
          Zakaži termin
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <button
          id="burger"
          aria-label="Meni"
          class="group hidden cursor-pointer flex-col gap-[5px] rounded-lg border border-border p-[9px] max-md:flex">
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:translate-y-[6.5px] group-[.open]:rotate-45"
          ></span>
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:opacity-0"
          ></span>
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:-translate-y-[6.5px] group-[.open]:-rotate-45"
          ></span>
        </button>
      </div>
    </div>
  </header>

  <main id="top">
    <!-- ===================== HERO ===================== -->
    <section class="relative pt-[140px] pb-[60px] max-md:pt-24 max-[480px]:pt-[88px]">
      <div class="container grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-[60px]">
        <div>
          <div
            class="reveal inline-flex items-center gap-2 rounded-full border border-border-hi bg-surface px-3 py-1.5 text-[12.5px] font-medium text-text-2"
            data-d="0">
            <span class="badge-live"></span>
            Top Salon 2021 & 2022 · Novi Sad
          </div>

          <h1
            class="reveal mt-[22px] text-[clamp(48px,7vw,80px)] font-extrabold leading-none tracking-[-0.03em] text-text max-[480px]:text-[clamp(38px,12vw,50px)]"
            data-d="1">
            Tvoja<br />
            <em class="italic text-accent">savršena</em><br />
            frizura.
          </h1>

          <p
            class="reveal mt-[22px] max-w-[440px] text-base leading-[1.65] text-text-2 max-[480px]:text-[15px]"
            data-d="2">
            Premium frizerski salon u srcu Novog Sada. Vrhunska usluga, savremene tehnike i online
            zakazivanje — u par klikova, 24/7.
          </p>

          <div class="reveal mt-8 flex flex-wrap gap-2.5 max-[480px]:gap-2" data-d="3">
            <a
              href="#booking"
              class="btn-primary max-md:flex-1 max-md:justify-center max-[480px]:w-full">
              Zakaži termin
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
              >
            </a>
            <a
              href={salon.phoneBookingHref}
              class="btn-secondary max-md:flex-1 max-md:justify-center max-[480px]:w-full">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2">
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.81.37 1.6.72 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.74-1.01a2 2 0 0 1 2.11-.45c.74.35 1.53.6 2.34.72A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              {salon.phoneBooking}
            </a>
          </div>

          <div class="reveal mt-6 flex items-center gap-2.5" data-d="4">
            <div class="flex gap-0.5">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path></svg
              >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path></svg
              >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path></svg
              >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path></svg
              >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path></svg
              >
            </div>
            <span class="text-[13px] text-text-2"
              ><strong class="text-text">9.5/10</strong> · 296 recenzija</span
            >
          </div>
        </div>

        <div class="reveal order-first lg:order-none" data-d="2">
          <!-- ZAMENI src sa pravom slikom salona -->
          <div
            class="group relative overflow-hidden rounded-[var(--r-xl)] border border-border shadow-[0_40px_80px_-20px_rgba(0,0,0,0.7)]">
            <img
              src="https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?auto=format&fit=crop&w=900&q=90"
              alt="Enterijer salona Candir — Novi Sad"
              class="block h-[520px] w-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.03] max-lg:h-[380px] max-md:h-[340px] max-[480px]:h-[280px]"
              loading="eager"
              width="900"
              height="600"
            />
            <div
              class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,transparent_50%,rgba(13,13,15,0.6))]">
            </div>

            <div class="floating-card fc-top">
              <div class="fc-dot"></div>
              <div class="fc-text">
                <span class="fc-label">Slobodni termini</span>
                <span class="fc-value">4 dostupna danas</span>
              </div>
            </div>

            <div class="floating-card fc-bottom">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#22c55e"
                stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg
              >
              <div class="fc-text">
                <span class="fc-label">Instant potvrda</span>
                <span class="fc-value">bez čekanja na poziv</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- stats bar -->
      <div class="reveal mt-14" data-d="4">
        <div
          class="container flex items-center rounded-lg border border-border bg-bg-elevated px-8 py-6 max-md:flex-wrap max-md:gap-3 max-md:p-5">
          {
            stats.map((s, i) => (
              <>
                <div class="flex-1 text-center max-md:flex-[1_1_calc(50%-6px)]">
                  <div
                    class="text-[clamp(26px,3.5vw,38px)] font-extrabold tracking-[-0.02em] text-text"
                    data-count={s.broj}>
                    {s.broj}
                    <span class="text-accent" data-suf>
                      {s.sufiks}
                    </span>
                  </div>
                  <div class="mt-[3px] text-[12.5px] font-medium text-text-3">{s.labela}</div>
                </div>
                {i < stats.length - 1 && (
                  <div class="h-9 w-px shrink-0 bg-border max-md:hidden" aria-hidden="true" />
                )}
              </>
            ))
          }
