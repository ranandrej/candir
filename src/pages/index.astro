    }
  }
</style>

<script>
  // ---- SPLASH ----
  // Puna animacija samo jednom po sesiji; uz reduced-motion se preskače.
  const splash = document.getElementById('splash')
  let splashDelay = 0
  if (splash) {
    const skipSplash =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      sessionStorage.getItem('candirSplash')
    if (skipSplash) {
      splash.remove()
    } else {
      sessionStorage.setItem('candirSplash', '1')
      splashDelay = 2100
      document.body.style.overflow = 'hidden'
      window.setTimeout(() => splash.classList.add('cut'), 1950)
      window.setTimeout(() => {
        splash.remove()
        document.body.style.overflow = ''
      }, 2700)
    }
  }

  // ---- NAV ----
  const nav = document.getElementById('nav')
  const burger = document.getElementById('burger')
  const navLinks = document.getElementById('navLinks')

  const setScrolledNav = () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled')
    } else {
      nav?.classList.remove('scrolled')
    }
  }
  setScrolledNav()
  window.addEventListener('scroll', setScrolledNav, { passive: true })

  const closeMenu = () => {
    burger?.classList.remove('open')
    burger?.setAttribute('aria-expanded', 'false')
    navLinks?.classList.remove('open')
  }
  burger?.addEventListener('click', () => {
    const isOpen = burger.classList.toggle('open')
    burger.setAttribute('aria-expanded', String(isOpen))
    navLinks?.classList.toggle('open', isOpen)
  })
  navLinks?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      closeMenu()
    })
  )
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeMenu()
  })

  // ---- REVEAL ----
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal')
  if (prefersReducedMotion || !('IntersectionObserver' in window)) {
    revealEls.forEach(el => el.classList.add('in'))
  } else {
    const io = new IntersectionObserver(
      entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement
            const d = Number(el.dataset.d || 0) * 80
            setTimeout(() => el.classList.add('in'), d)
            io.unobserve(el)
          }
        })
      },
      { threshold: 0.1 }
    )
    revealEls.forEach(el => io.observe(el))
  }

  // ---- HERO TYPEWRITER ----
  const twTitle = document.querySelector<HTMLElement>('[data-typewriter]')
  if (twTitle && !prefersReducedMotion) {
    const scissors = twTitle.querySelector<HTMLElement>('.ht-scissors')
    const data = Array.from(twTitle.querySelectorAll<HTMLElement>('.ht-line')).map(line => ({
      line,
      ink: line.querySelector<HTMLElement>('.ht-ink'),
      text: line.dataset.text || '',
    }))

    const positionScissors = (line: HTMLElement, ink: HTMLElement) => {
      if (!scissors) return
      const x = line.offsetLeft + ink.offsetWidth
      const y = line.offsetTop + line.offsetHeight
      scissors.style.transform = `translate(${x}px, ${y}px)`
    }

    data.forEach(d => {
      if (d.ink) d.ink.textContent = ''
    })

    const typeLine = (idx: number) => {
      if (idx >= data.length) {
        twTitle.classList.remove('is-typing')
        scissors?.classList.remove('cutting')
        return
      }
      const { line, ink, text } = data[idx]
      if (!ink) return typeLine(idx + 1)
      line.classList.add('typing')
      let i = 0
      const step = () => {
        ink.textContent = text.slice(0, i)
        positionScissors(line, ink)
        if (i < text.length) {
          i++
          window.setTimeout(step, 58 + Math.random() * 55)
        } else {
          line.classList.remove('typing')
          window.setTimeout(() => typeLine(idx + 1), 250)
        }
      }
      step()
    }

    window.setTimeout(() => {
      twTitle.classList.add('is-typing')
      scissors?.classList.add('cutting')
      typeLine(0)
    }, 320 + splashDelay)
  }

  // ---- HERO STACK CAROUSEL ----
  const stack = document.querySelector<HTMLElement>('[data-stack]')
  if (stack) {
    const cards = Array.from(stack.querySelectorAll<HTMLElement>('.hero-card'))
    const posClasses = ['pos-0', 'pos-1', 'pos-2']
    let order = cards.map((_, i) => i)

    const render = () => {
      order.forEach((cardIdx, posIdx) => {
        const card = cards[cardIdx]
        posClasses.forEach(p => card.classList.remove(p))
        card.classList.add(posClasses[Math.min(posIdx, posClasses.length - 1)])
        if (posIdx === 0) card.setAttribute('aria-current', 'true')
        else card.removeAttribute('aria-current')
      })
    }
    const bringToFront = (cardIdx: number) => {
      order = [cardIdx, ...order.filter(i => i !== cardIdx)]
      render()
    }
    const next = () => {
      order = [...order.slice(1), order[0]]
      render()
    }
    const prev = () => {
      order = [order[order.length - 1], ...order.slice(0, -1)]
      render()
    }

    let swiped = false
    cards.forEach((card, idx) => {
      card.addEventListener('click', () => {
        if (swiped) return
        if (card.classList.contains('pos-0')) next()
        else bringToFront(idx)
      })
    })

    let startX: number | null = null
    stack.addEventListener('pointerdown', e => {
      startX = e.clientX
      swiped = false
    })
    stack.addEventListener('pointerup', e => {
      if (startX === null) return
      const dx = e.clientX - startX
      startX = null
      if (Math.abs(dx) > 45) {
        swiped = true
        ;(dx < 0 ? next : prev)()
        window.setTimeout(() => {
          swiped = false
        }, 50)
      }
    })

    render()
  }

  // ---- MAPA (Leaflet — pomeranje i zum ograničeni na okolinu salona) ----
  const mapEl = document.getElementById('salonMap')
  const initSalonMap = () => {
    const L = (window as any).L
    if (!mapEl || !L || (mapEl as any)._leaflet_id) return

    const salonPos: [number, number] = [45.2526654, 19.7966644]
    // granice ~1km oko salona — dalje od toga mapa "gura" nazad
    const bounds = L.latLngBounds([45.2436654, 19.7796644], [45.2616654, 19.8136644])

    const map = L.map(mapEl, {
      center: salonPos,
      zoom: 16,
      minZoom: 14,
      maxZoom: 18,
      maxBounds: bounds,
      maxBoundsViscosity: 1.0,
      scrollWheelZoom: false, // zum na +/- dugmiće ili dvoklik, da skrol stranice ne zapinje
    })

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map)

    L.marker(salonPos, {
      icon: L.divIcon({
        className: 'salon-pin',
        html: '<span class="salon-pin-ring"></span><span class="salon-pin-dot"></span>',
        iconSize: [18, 18],
        iconAnchor: [9, 9],
      }),
      keyboard: false,
      title: 'Salon Candir — Bate Brkića 26',
    }).addTo(map)
  }
  if ((window as any).L) initSalonMap()
  else window.addEventListener('load', initSalonMap)

  // ---- HORIZONTALNE TRAKE (galerija, meni usluga) — drag mišem + wheel skrol ----
  // Na touch uređajima prevlačenje radi nativno; drag logika je samo za miša.
  const enableDragScroll = (el: HTMLElement) => {
    el.addEventListener(
      'wheel',
      e => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX) && el.scrollWidth > el.clientWidth) {
          e.preventDefault()
          el.scrollLeft += e.deltaY
        }
      },
      { passive: false }
    )

    let down = false
    let moved = false
    let startX = 0
    let startScroll = 0
    el.addEventListener('pointerdown', e => {
      if (e.pointerType !== 'mouse' || el.scrollWidth <= el.clientWidth) return
      down = true
      moved = false
      startX = e.clientX
      startScroll = el.scrollLeft
    })
    el.addEventListener('pointermove', e => {
      if (!down) return
      const dx = e.clientX - startX
      if (!moved && Math.abs(dx) > 5) {
        moved = true
        el.classList.add('dragging')
        el.setPointerCapture(e.pointerId)
      }
      if (moved) el.scrollLeft = startScroll - dx
    })
    const endDrag = () => {
      down = false
      el.classList.remove('dragging')
      window.setTimeout(() => {
        moved = false
      }, 0)
    }
    el.addEventListener('pointerup', endDrag)
    el.addEventListener('pointercancel', endDrag)
    // posle prevlačenja ne aktiviraj klik na dugme/karticu ispod kursora
    el.addEventListener(
      'click',
      e => {
        if (moved) {
          e.preventDefault()
          e.stopPropagation()
        }
      },
      true
    )
  }
  document
    .querySelectorAll<HTMLElement>('[data-gallery], .svc-nav')
    .forEach(enableDragScroll)

  // galerija na startu centrirana (jednako "iseckana" levo i desno)
  const galleryStrip = document.querySelector<HTMLElement>('[data-gallery]')
  if (galleryStrip) {
    galleryStrip.scrollLeft = (galleryStrip.scrollWidth - galleryStrip.clientWidth) / 2
  }

  // ---- USLUGE MENI ----
  const svcMenu = document.querySelector<HTMLElement>('[data-svc-menu]')
  if (svcMenu) {
    const svcTabs = svcMenu.querySelectorAll<HTMLElement>('[data-svc-tab]')
    const svcPanels = svcMenu.querySelectorAll<HTMLElement>('[data-svc-panel]')
    const svcProgress = svcMenu.querySelector<HTMLElement>('[data-svc-progress]')
    const total = svcTabs.length

    const activateSvc = (idx: number) => {
      svcTabs.forEach(t => {
        const on = Number(t.dataset.svcTab) === idx
        t.classList.toggle('active', on)
        t.setAttribute('aria-selected', String(on))
      })
      svcPanels.forEach(p => {
        const on = Number(p.dataset.svcPanel) === idx
        p.classList.toggle('active', on)
        p.setAttribute('aria-hidden', String(!on))
      })
      if (svcProgress) svcProgress.style.width = `${((idx + 1) / total) * 100}%`
      svcTabs[idx]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' })
    }

    svcTabs.forEach(tab => {
      tab.addEventListener('click', () => activateSvc(Number(tab.dataset.svcTab)))
    })
  }

  // ---- PRICE TABS ----
  const ptabs = document.querySelectorAll<HTMLElement>('.ptab')
  const ppanels = document.querySelectorAll<HTMLElement>('.ppanel')
  ptabs.forEach(tab =>
    tab.addEventListener('click', () => {
      ptabs.forEach(t => {
        t.classList.remove('active')
        t.setAttribute('aria-selected', 'false')
      })
      ppanels.forEach(p => {
        p.classList.remove('active')
        p.setAttribute('aria-hidden', 'true')
      })
      tab.classList.add('active')
      tab.setAttribute('aria-selected', 'true')
      const idx = tab.dataset.tab
      const panel = document.querySelector(`.ppanel[data-panel="${idx}"]`)
      panel?.classList.add('active')
      panel?.setAttribute('aria-hidden', 'false')
    })
  )

  // ---- BOOKING MODAL ----
  // Logika modala (otvaranje/zatvaranje, koraci, kalendar) je u
  // src/components/BookingModal.astro
</script>
