---

<Layout>
  <!-- ===================== SPLASH ===================== -->
  <div id="splash" aria-hidden="true">
    <div class="splash-half splash-top"></div>
    <div class="splash-half splash-bottom"></div>
    <div class="splash-cutline"></div>
    <div class="splash-brand">
      <span class="splash-logo">
        <svg width="26" height="26" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M8 1.5C4.41 1.5 1.5 4.41 1.5 8C1.5 11.59 4.41 14.5 8 14.5C11.59 14.5 14.5 11.59 14.5 8"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"></path>
          <path
            d="M11 4L14.5 4L14.5 7.5"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <path d="M14.5 4L9 9.5" stroke="white" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </span>
      <span class="splash-name">
        {'CANDIR'.split('').map((ch, i) => <span style={`--i:${i}`}>{ch}</span>)}
      </span>
    </div>
    <span class="splash-sub">Frizerski salon · Novi Sad</span>
    <span class="splash-scissors" aria-hidden="true">
      <svg viewBox="0 0 64 64" fill="none">
        <circle cx="18" cy="47" r="8" stroke="currentColor" stroke-width="4"></circle>
        <circle cx="18" cy="17" r="8" stroke="currentColor" stroke-width="4"></circle>
        <path
          d="M25 43L54 14M25 21l29 29M27 32h8"
          stroke="currentColor"
          stroke-width="4"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
  </div>

  <!-- ===================== NAV ===================== -->
  <header
    id="nav"
    class="fixed inset-x-0 top-0 z-[100] border-b border-transparent py-3.5 transition-all duration-300 [&.scrolled]:border-border [&.scrolled]:bg-[rgba(8,8,11,0.84)] [&.scrolled]:py-2.5 [&.scrolled]:shadow-[0_18px_60px_-34px_rgba(0,0,0,0.9)] [&.scrolled]:backdrop-blur-xl">
    <div class="mx-auto flex w-[min(1160px,92vw)] items-center justify-between gap-4">
      <a href="#top" aria-label="Candir" class="group inline-flex shrink-0 items-center gap-[9px]">
        <span
          class="grid h-[30px] w-[30px] shrink-0 place-items-center rounded-lg bg-[var(--accent-gradient)] shadow-[var(--accent-glow)] transition-transform duration-300 group-hover:-rotate-[8deg]">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path
              d="M8 1.5C4.41 1.5 1.5 4.41 1.5 8C1.5 11.59 4.41 14.5 8 14.5C11.59 14.5 14.5 11.59 14.5 8"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"></path>
            <path
              d="M11 4L14.5 4L14.5 7.5"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path d="M14.5 4L9 9.5" stroke="white" stroke-width="1.5" stroke-linecap="round"></path>
          </svg>
        </span>
        <span class="font-sans text-[15px] font-bold tracking-[0.12em] text-text">CANDIR</span>
      </a>

      <nav
        id="navLinks"
        aria-label="Glavna navigacija"
        class="ml-auto flex gap-0.5 max-md:fixed max-md:inset-x-0 max-md:bottom-auto max-md:top-[58px] max-md:z-[99] max-md:invisible max-md:-translate-y-3 max-md:flex-col max-md:border-y max-md:border-border max-md:bg-[rgba(8,8,11,0.96)] max-md:px-[5vw] max-md:pb-5 max-md:pt-3.5 max-md:opacity-0 max-md:shadow-[0_26px_80px_-34px_rgba(0,0,0,0.95)] max-md:backdrop-blur-xl max-md:transition-all max-md:duration-300 max-md:[&.open]:visible max-md:[&.open]:translate-y-0 max-md:[&.open]:opacity-100">
        {
          navLinks.map(l => (
            <a
              href={l.href}
              class="rounded-lg px-3 py-[7px] text-[15.5px] font-medium text-text-2 transition-colors hover:bg-surface hover:text-text max-md:px-4 max-md:py-[13px] max-md:text-base">
              {l.label}
            </a>
          ))
        }
      </nav>

      <div class="ml-3 flex items-center gap-2">
        <a
          href={salon.phoneBookingHref}
          title="Pozovi"
          class="flex items-center gap-[7px] rounded-lg border border-border px-3 py-[7px] text-[14px] text-text-2 transition-colors hover:border-border-hi hover:bg-surface hover:text-text">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8">
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.81.37 1.6.72 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.74-1.01a2 2 0 0 1 2.11-.45c.74.35 1.53.6 2.34.72A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span class="hidden min-[1080px]:block">{salon.phoneBooking}</span>
        </a>
        <a
          href="#booking"
          class="inline-flex items-center gap-[7px] whitespace-nowrap rounded-lg bg-accent px-4 py-2 text-[14.5px] font-semibold text-white transition hover:-translate-y-px hover:bg-accent-2 max-md:hidden">
          Zakaži termin
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <button
          id="burger"
          type="button"
          aria-label="Meni"
          aria-controls="navLinks"
          aria-expanded="false"
          class="group hidden cursor-pointer flex-col gap-[5px] rounded-lg border border-border p-[9px] max-md:flex">
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:translate-y-[6.5px] group-[.open]:rotate-45"
          ></span>
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:opacity-0"
          ></span>
          <span
            class="block h-[1.5px] w-[18px] rounded-sm bg-text-2 transition-all duration-300 group-[.open]:-translate-y-[6.5px] group-[.open]:-rotate-45"
          ></span>
        </button>
      </div>
    </div>
  </header>

  <main id="top">
    <!-- ===================== HERO ===================== -->
    <section class="relative overflow-hidden pt-[132px] pb-[60px] max-md:pt-24 max-[480px]:pt-[92px]">
      <div class="hero-scissors" aria-hidden="true">
        {
          [
            {
              icon: 'scissors',
              left: '5%',
              top: '15%',
              tx: '96px',
              ty: '-44px',
              rot: '-18deg',
              rotMid: '18deg',
              scale: '0.92',
              dur: '13s',
              delay: '-3s',
            },
            {
              icon: 'comb',
              left: '17%',
              top: '34%',
              tx: '72px',
              ty: '46px',
              rot: '84deg',
              rotMid: '126deg',
              scale: '0.74',
              dur: '16s',
              delay: '-7s',
            },
            {
              icon: 'clipper',
              left: '29%',
              top: '27%',
              tx: '-86px',
              ty: '-38px',
              rot: '28deg',
              rotMid: '-22deg',
              scale: '0.58',
              dur: '15s',
              delay: '-12s',
            },
            {
              icon: 'razor',
              left: '43%',
              top: '9%',
              tx: '-78px',
              ty: '64px',
              rot: '22deg',
              rotMid: '-18deg',
              scale: '0.72',
              dur: '14s',
              delay: '-8s',
            },
            {
              icon: 'pole',
              left: '57%',
              top: '23%',
              tx: '78px',
              ty: '-46px',
              rot: '-8deg',
              rotMid: '20deg',
              scale: '0.72',
              dur: '17s',
              delay: '-2s',
            },
            {
              icon: 'scissors',
              left: '82%',
              top: '20%',
              tx: '-112px',
              ty: '-34px',
              rot: '-34deg',
              rotMid: '14deg',
              scale: '0.86',
              dur: '16s',
              delay: '-5s',
            },
            {
              icon: 'brush',
              left: '13%',
              top: '68%',
              tx: '82px',
              ty: '48px',
              rot: '18deg',
