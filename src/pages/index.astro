<style>
  /* ============================================================
   Dizajn tokeni, fontovi i base reset su u src/styles/global.css
   (Tailwind v4 @theme). Ovde ostaju samo stilovi specifični za
   ovu stranicu — postepeno se prebacuju na Tailwind utility klase.
   ============================================================ */
  .container {
    width: min(1160px, 92vw);
    margin: 0 auto;
  }

  /* ============================================================
   SPLASH — uvodni ekran: logo + makaze koje "preseku" ekran
   ============================================================ */
  #splash {
    position: fixed;
    inset: 0;
    z-index: 400;
  }
  #splash.cut {
    pointer-events: none;
  }
  .splash-half {
    position: absolute;
    left: 0;
    right: 0;
    height: 50.5%;
    background: #08080b;
    transition: transform 0.65s cubic-bezier(0.7, 0, 0.25, 1);
  }
  .splash-top {
    top: 0;
  }
  .splash-bottom {
    bottom: 0;
  }
  #splash.cut .splash-top {
    transform: translateY(-101%);
  }
  #splash.cut .splash-bottom {
    transform: translateY(101%);
  }
  .splash-brand {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(50% + 26px);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .splash-logo {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 16px;
    background: var(--accent-gradient);
    box-shadow: var(--accent-glow);
    opacity: 0;
    animation: splashPop 0.7s cubic-bezier(0.16, 1.4, 0.3, 1) 0.1s both;
  }
  .splash-name {
    display: flex;
    font-size: clamp(34px, 7vw, 54px);
    font-weight: 800;
    letter-spacing: 0.22em;
    margin-right: -0.22em;
    color: var(--text);
  }
  .splash-name span {
    display: inline-block;
    opacity: 0;
    animation: splashRise 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.32s + var(--i) * 0.07s);
  }
  .splash-sub {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(50% + 26px);
    z-index: 1;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0;
    animation: splashRise 0.6s ease 0.9s both;
  }
  .splash-cutline {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    z-index: 1;
    border-top: 2px dashed rgba(255, 99, 99, 0.55);
    transform: scaleX(0);
    transform-origin: left;
    animation: splashCutGrow 0.85s ease-in-out 1.05s both;
  }
  .splash-scissors {
    position: absolute;
    top: 50%;
    left: -8%;
    z-index: 2;
    width: clamp(38px, 5vw, 52px);
    margin-top: calc(clamp(38px, 5vw, 52px) / -2);
    color: var(--accent);
    filter: drop-shadow(0 0 14px rgba(255, 99, 99, 0.55));
    animation: splashTravel 0.85s ease-in-out 1.05s both;
  }
  .splash-scissors svg {
    display: block;
    width: 100%;
    height: auto;
    transform-origin: 30% 50%;
    animation: scissorSnip 0.3s ease-in-out infinite;
  }
  #splash.cut .splash-brand,
  #splash.cut .splash-sub,
